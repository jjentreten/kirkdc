# Porta do servidor (opcional; padrão 3000)
PORT=3000

# URL pública do site (para webhooks — deve ser HTTPS em produção)
SITE_URL=http://localhost:3000

# --- Pagou (PIX + Cartão) ---
# Chaves em: painel Pagou → Configurações → Credenciais de API
PAGOU_API_KEY=
PAGOU_PUBLIC_KEY=

# Ambiente: sandbox | production
PAGOU_ENV=sandbox

# --- Utmify (trackeamento de vendas) ---
# Token em: painel Utmify → API
UTMIFY_API_TOKEN=
