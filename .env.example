# Porta do servidor (opcional; padrão 3000)
PORT=3000

# URL pública do site (para webhooks e redirects)
SITE_URL=http://localhost:3000

# --- PIX: escolha o provedor ---
# brutalcash = BrutalCash (ativo por padrão)
# marchapay = Marcha Pay (legado)
PIX_PROVIDER=brutalcash

# --- BrutalCash (quando PIX_PROVIDER=brutalcash) ---
# Credenciais em: painel BrutalCash → Credenciais API
BRUTALCASH_PUBLIC_KEY=
BRUTALCASH_SECRET_KEY=

# --- Marcha Pay (quando PIX_PROVIDER=marchapay) ---
MARCHABB_PUBLIC_KEY=
MARCHABB_SECRET_KEY=

# --- Utmify (trackeamento de vendas) ---
# Token em: painel Utmify → API
UTMIFY_API_TOKEN=
