# Porta do servidor (opcional; padrão 3000)
PORT=3000

# URL pública do site (deve ser HTTPS em produção — usada no notify_url da Pagou)
SITE_URL=https://seusite.com.br

# --- Pagou (PIX + Cartão) ---
# Chaves em: painel Pagou → Configurações → Credenciais de API
PAGOU_API_KEY=sk_live_...
PAGOU_PUBLIC_KEY=pk_live_...

# Ambiente: sandbox | production
# sandbox  → https://api-sandbox.pagou.ai
# production → https://api.pagou.ai
PAGOU_ENV=production

# Origem(ns) permitidas no CORS — separadas por vírgula, sem espaços
# Deixe vazio para permitir todas (apenas em desenvolvimento)
CORS_ORIGIN=https://seusite.com.br,https://www.seusite.com.br

# --- Utmify (trackeamento de vendas) ---
# Token em: painel Utmify → API
UTMIFY_API_TOKEN=
